{
    "version": "2.0.0",
    "tasks": [
        {
            /* Task 1: Bài tập thường */
            "type": "cppbuild",
            "label": "Build C++ Thuong",
            "command": "C:/raylib/w64devkit/bin/g++.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}\\${fileBasenameNoExtension}.exe"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": ["$gcc"],
            "group": "build"  /* <--- Đã sửa đoạn này cho ngắn gọn */
        },
        {
            /* Task 2: Tool Raylib */
            "type": "shell",
            "label": "Build Raylib Tool", 
            "command": "C:/raylib/w64devkit/bin/g++.exe",
            "args": [
                "-g",
                "${file}",
                "-o",
                "${fileDirname}\\${fileBasenameNoExtension}.exe",
                "-O1",
                "-Wall",
                "-std=c99",
                "-Wno-missing-braces",
                "-I", "C:/raylib/raylib/src",
                "-L", "C:/raylib/raylib/src",
                "-lraylib",
                "-lopengl32",
                "-lgdi32",
                "-lwinmm",
                "-static",
                "-static-libgcc",
                "-static-libstdc++"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": ["$gcc"],
            "group": "build"
        }
    ]
}